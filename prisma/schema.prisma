generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Agent {
  id          String   @id
  name        String
  role        String
  category    String
  personality String
  model       String   @default("google/gemini-2.0-flash-lite:free")
  sprite      String
  effortLevel Int      @default(1)
  skills      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  tasks       Task[]
}

model Task {
  id          String   @id @default(cuid())
  title       String
  status      String   @default("pending")
  progress    Int      @default(0)
  result      String?
  summary     String?
  searchQuery String?
  searchUsed  Boolean  @default(false)
  agentId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  agent       Agent?   @relation(fields: [agentId], references: [id])
}

model Memory {
  id        String   @id @default(cuid())
  key       String
  value     String
  category  String   @default("Personal")
  agentName String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Knowledge {
  topic     String
  content   String
  category  String   @default("General")
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  id        BigInt   @id @default(autoincrement())
}
